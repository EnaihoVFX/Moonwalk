{
  "name": "research_to_local_file",
  "priority": 112,
  "version": "1",
  "tags": ["research", "local_first", "file_output"],
  "skill": {
    "name": "research_to_local_file_skill",
    "description": "Research a topic and save findings to a local file path.",
    "examples": [
      "research UK housing and save to notes.md",
      "investigate this and write to /tmp/report.txt",
      "find details and save summary in results.md"
    ],
    "capabilities_all": ["research", "file_output"],
    "capabilities_any": ["browser_read"],
    "anti_patterns": ["google doc", "google document"],
    "min_semantic_score": 0.16,
    "semantic_weight": 8.8
  },
  "match": {
    "intent_actions": ["search", "create", "analyze", "unknown"],
    "regex_any": [
      "(research|investigate|find|compare|study|analy[sz]e).*(?:save|write).*(?:to|into|in)\\s+(?P<path>[~/\\w./-]+\\.(?:md|txt|rtf|doc|docx))",
      "(?:save|write).*(document|report|summary).*(?:to|into|in)\\s+(?P<path>[~/\\w./-]+\\.(?:md|txt|rtf|doc|docx)).*(research|investigate|find|compare|study|analy[sz]e)"
    ]
  },
  "plan": {
    "task_summary": "Research topic and save findings to a local file",
    "steps": [
      {
        "description": "Search web for the topic",
        "tool": "open_url",
        "args": {
          "url": "https://www.google.com/search?q={query_urlencoded}"
        },
        "success_criteria": "Search results opened",
        "wait_after": 0
      },
      {
        "description": "Read page content for research notes",
        "tool": "browser_read_page",
        "args": {
          "query": "{query}"
        },
        "success_criteria": "Research notes captured",
        "wait_after": 0
      },
      {
        "description": "Write research summary to local file",
        "tool": "write_file",
        "args": {
          "path": "{path}",
          "content": "{step2_result}"
        },
        "success_criteria": "File written with summary",
        "wait_after": 0
      }
    ]
  },
  "constraints": {
    "required_tools": ["browser_read_page", "write_file"],
    "min_steps": 3,
    "max_steps": 5
  },
  "final_response": "Research complete and saved to {path}."
}
