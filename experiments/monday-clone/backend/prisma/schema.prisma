// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  workspaces Workspace[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  boards    Board[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Board {
  id          String   @id @default(uuid())
  name        String
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  groups      Group[]
  columns     Column[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Group {
  id        String   @id @default(uuid())
  title     String
  color     String   @default("#579bfc")
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id])
  items     Item[]
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Item {
  id        String   @id @default(uuid())
  name      String
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id])
  values    CellValue[]
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Column {
  id        String   @id @default(uuid())
  title     String
  type      String   // 'text', 'status', 'date', 'people', etc.
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id])
  settings  String?  // JSON string for column-specific settings (e.g., status labels)
  values    CellValue[]
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CellValue {
  id        String   @id @default(uuid())
  value     String?  // The actual data stored
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id])
  columnId  String
  column    Column   @relation(fields: [columnId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([itemId, columnId])
}
