// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  description String?
  boards      Board[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Board {
  id          String   @id @default(cuid())
  name        String
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  groups      Group[]
  columns     Column[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Column {
  id        String   @id @default(cuid())
  title     String
  type      String   // e.g., "text", "status", "date", "person"
  settings  String?  // JSON string for column-specific settings (e.g., status labels)
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id])
  values    ColumnValue[]
  position  Int      @default(0)
}

model Group {
  id        String   @id @default(cuid())
  title     String
  color     String   @default("#579bfc")
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id])
  items     Item[]
  position  Int      @default(0)
}

model Item {
  id        String   @id @default(cuid())
  name      String
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id])
  values    ColumnValue[]
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ColumnValue {
  id        String   @id @default(cuid())
  value     String?  // The actual data stored as a string or JSON string
  columnId  String
  column    Column   @relation(fields: [columnId], references: [id])
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id])

  @@unique([columnId, itemId])
}
